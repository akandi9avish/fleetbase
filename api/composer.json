{
    "name": "fleetbase/fleetbase",
    "type": "project",
    "description": "Modular logistics and supply chain operating system (LSOS)",
    "keywords": [
        "framework",
        "laravel"
    ],
    "license": "AGPL-3.0-or-later",
    "authors": [
        {
            "name": "Fleetbase Pte Ltd.",
            "email": "hello@fleetbase.io"
        },
        {
            "name": "Ronald A. Richardson",
            "email": "ron@fleetbase.io"
        }
    ],
    "require": {
        "php": ">=8.0 <=8.2.30",
        "appstract/laravel-opcache": "^4.0",
        "fleetbase/core-api": "dev-main",
        "fleetbase/fleetops-api": "dev-main",
        "fleetbase/registry-bridge": "dev-main",
        "fleetbase/storefront-api": "dev-main",
        "reeup/integration": "*",
        "guzzlehttp/guzzle": "^7.0.1",
        "laravel/framework": "^10.0",
        "laravel/octane": "^2.3",
        "laravel/tinker": "^2.9",
        "league/flysystem-aws-s3-v3": "^3.0",
        "maatwebsite/excel": "^3.1",
        "maennchen/zipstream-php": "3.1.2",
        "phpoffice/phpspreadsheet": "^1.28",
        "predis/predis": "^2.1",
        "psr/http-factory-implementation": "*",
        "resend/resend-php": "^0.14.0",
        "s-ichikawa/laravel-sendgrid-driver": "^4.0",
        "stripe/stripe-php": "^17.0",
        "symfony/mailgun-mailer": "^7.1",
        "symfony/postmark-mailer": "^7.1",
        "open-telemetry/api": "^1.0",
        "open-telemetry/sdk": "^1.0",
        "open-telemetry/exporter-otlp": "^1.0",
        "open-telemetry/sem-conv": "^1.0"
    },
    "require-dev": {
        "spatie/laravel-ignition": "^2.0",
        "fakerphp/faker": "^1.9.1",
        "laravel/sail": "^1.0.1",
        "mockery/mockery": "^1.4.4",
        "nunomaduro/collision": "^7.0",
        "phpunit/phpunit": "^10.0"
    },
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/akandi9avish/core-api"
        },
        {
            "type": "vcs",
            "url": "https://github.com/akandi9avish/fleetops"
        },
        {
            "type": "vcs",
            "url": "https://github.com/akandi9avish/registry-bridge"
        },
        {
            "type": "vcs",
            "url": "https://github.com/akandi9avish/storefront"
        },
        {
            "type": "path",
            "url": "../packages/reeup-integration"
        }
    ],
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        },
        "platform": {
            "php": "8.2.30"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
